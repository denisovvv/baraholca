# ============================================================
# Шаблон переменных окружения для Baraxolka backend.
#
# Скопируйте этот файл в .env и заполните реальными значениями.
# Файл .env НЕ коммитится в git (он в .gitignore).
# Этот шаблон (.env.example) коммитится — он без секретов.
# ============================================================

# --- Django ---

# Секретный ключ Django. Сгенерировать новый можно командой:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# Режим отладки. На локальной машине: True. На проде: False (или не указывать).
DEBUG=True

# Разрешённые хосты через запятую без пробелов.
# Локально: localhost,127.0.0.1
# На проде: api.baraxolka.ru (или ваш домен)
ALLOWED_HOSTS=localhost,127.0.0.1

# --- База данных (PostgreSQL + PostGIS) ---

DATABASE_NAME=baraxolka_dev
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_HOST=localhost
DATABASE_PORT=5432
# --- SMS-провайдер ---
# Какой провайдер использовать: console (код в лог, для разработки)
# или sms_aero (реальная отправка через smsaero.ru).
SMS_PROVIDER=console

# SMS Aero (заполнить, если SMS_PROVIDER=sms_aero).
# Email — логин аккаунта; API-ключ — Настройки > API и SMPP.
SMSAERO_EMAIL=
SMSAERO_API_KEY=
# Имя отправителя. До одобрения своего имени можно "SMS Aero".
SMSAERO_SIGN=SMS Aero
# Тестовый режим: True — endpoint testsend (нужна активация у SMS Aero),
# False — реальная отправка. По умолчанию True (безопасно).
SMSAERO_TEST_MODE=True
